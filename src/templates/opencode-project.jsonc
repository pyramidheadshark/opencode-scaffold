{
  "$schema": "https://opencode.ai/config.json",
  "model": "z-ai/glm-5.1",
  "small_model": "z-ai/glm-4.7",
  "provider": {
    "z-ai": {
      "options": {
        "apiKey": "{env:Z_AI_API_KEY}",
        "baseURL": "https://api.z.ai/api/paas/v4"
      }
    },
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "baseURL": "https://openrouter.ai/api/v1"
      }
    }
  },
  "plugin": [
    "oh-my-openagent",
    "@tarquinen/opencode-dcp",
    "opencode-skillful",
    "opencode-mem",
    "opencode-vibeguard",
    "opencode-deepseek-thinking-fix",
    "opencode-command-hooks",
    "setu-opencode",
    "cc-safety-net",
    "opencode-injection-guard",
    "block-no-verify",
    "opencode-rules",
    "my-jogyo",
    "omo-pulse",
    "@lesquel/opencode-pilot",
    ["opencode-tool-search", {
      "alwaysLoad": ["read", "write", "edit", "bash", "glob", "grep", "lsp_diagnostics", "lsp_goto_definition", "lsp_find_references", "task", "todowrite", "compress"],
      "searchLimit": 5,
      "bm25": { "k1": 0.9, "b": 0.4 }
    }],
    "opencode-lazy-loader"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 15000
  },
  "mcp": {
    "sqlite": {
      "type": "local",
      "command": ["uvx", "mcp-server-sqlite"],
      "enabled": true
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": { "Authorization": "Bearer {env:Z_AI_API_KEY}" },
      "enabled": true
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": { "Authorization": "Bearer {env:Z_AI_API_KEY}" },
      "enabled": true
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": { "Authorization": "Bearer {env:Z_AI_API_KEY}" },
      "enabled": true
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "skill": "allow"
  },
  "agent": {
    "deep-worker": {
      "description": "Deep autonomous worker for complex multi-file implementation",
      "mode": "subagent",
      "model": "z-ai/glm-5.1",
      "temperature": 0.3,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "qa-engineer": {
      "description": "Strict QA engineer for E2E testing and defect reports",
      "mode": "subagent",
      "model": "z-ai/glm-4.7",
      "temperature": 0.2,
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    },
    "security-sentinel": {
      "description": "Security analyst - finds vulnerabilities, injection risks, supply chain flaws",
      "mode": "subagent",
      "model": "z-ai/glm-4.7",
      "permission": {
        "edit": "deny"
      }
    },
    "performance-analyst": {
      "description": "Performance analyst - Big-O, memory leaks, N+1 queries",
      "mode": "subagent",
      "model": "z-ai/glm-4.7",
      "permission": {
        "edit": "deny"
      }
    }
  }
}
