{
  "$schema": "https://opencode.ai/config.json",
  "model": "z-ai/glm-5.1",
  "small_model": "openai/gpt-5.4-nano",
  "provider": {
    "z-ai": {
      "options": {
        "apiKey": "{env:Z_AI_API_KEY}",
        "baseURL": "https://open.bigmodel.cn/api/paas/v4"
      }
    },
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      }
    },
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "baseURL": "https://openrouter.ai/api/v1"
      }
    }
  },
  "plugin": [
    "oh-my-openagent",
    "@tarquinen/opencode-dcp",
    "opencode-skillful",
    "opencode-mem",
    "opencode-vibeguard",
    "opencode-deepseek-thinking-fix",
    "opencode-command-hooks",
    "setu-opencode",
    "cc-safety-net",
    "opencode-injection-guard",
    "block-no-verify",
    "opencode-rules"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "skill": "allow"
  },
  "agent": {
    "deep-worker": {
      "description": "Deep autonomous worker for complex multi-file implementation",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "temperature": 0.3,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    }
  }
}
