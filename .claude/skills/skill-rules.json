{
  "version": "1.0",
  "description": "Skill auto-activation rules for claude-scaffold",
  "rules": [
    {
      "skill": "python-project-standards",
      "triggers": {
        "files": [
          "pyproject.toml",
          "*.py",
          ".pre-commit-config.yaml",
          "uv.lock"
        ],
        "keywords": [
          "lint",
          "ruff",
          "mypy",
          "type hint",
          "pre-commit",
          "uv",
          "dependency",
          "import"
        ],
        "always_load": true
      },
      "priority": 1
    },
    {
      "skill": "fastapi-patterns",
      "triggers": {
        "files": [
          "main.py",
          "routers/*.py",
          "api/*.py",
          "services/*.py",
          "adapters/*.py"
        ],
        "keywords": [
          "fastapi",
          "router",
          "endpoint",
          "pydantic",
          "dependency injection",
          "middleware",
          "lifespan",
          "роутер",
          "эндпоинт",
          "апи маршрут"
        ],
        "always_load": false
      },
      "priority": 2
    },
    {
      "skill": "htmx-frontend",
      "triggers": {
        "files": [
          "templates/*.html",
          "static/*.js",
          "static/*.css",
          "*.jinja2"
        ],
        "keywords": [
          "htmx",
          "jinja",
          "template",
          "frontend",
          "hx-get",
          "hx-post",
          "html"
        ],
        "always_load": false
      },
      "priority": 3
    },
    {
      "skill": "ml-data-handling",
      "triggers": {
        "files": [
          "*.pkl",
          "*.onnx",
          "*.parquet",
          "*.feather",
          "data/*.py",
          "datasets/*.py"
        ],
        "keywords": [
          "pickle",
          "onnx",
          "parquet",
          "s3",
          "dataset",
          "dataframe",
          "artifact",
          "dvc"
        ],
        "always_load": false
      },
      "priority": 4
    },
    {
      "skill": "multimodal-router",
      "triggers": {
        "files": [
          "*.pdf",
          "*.docx",
          "*.xlsx",
          "*.mp4",
          "*.mp3"
        ],
        "keywords": [
          "pdf",
          "docx",
          "image analysis",
          "video",
          "multimodal",
          "gemini",
          "openrouter",
          "large document",
          "extract text",
          "parse document"
        ],
        "min_keyword_matches": 2,
        "always_load": false
      },
      "priority": 21
    },
    {
      "skill": "langgraph-patterns",
      "triggers": {
        "files": [
          "graph.py",
          "agent*.py",
          "pipeline*.py",
          "workflow*.py",
          "nodes/*.py",
          "edges/*.py"
        ],
        "keywords": [
          "langgraph",
          "state",
          "graph",
          "node",
          "edge",
          "checkpointer",
          "agent",
          "tool",
          "interrupt",
          "ланграф",
          "агентный граф",
          "стейт машин"
        ],
        "min_keyword_matches": 2,
        "always_load": false
      },
      "priority": 6
    },
    {
      "skill": "infra-yandex-cloud",
      "triggers": {
        "files": [
          "*.tf",
          "*.pkr.hcl",
          "*.tfvars",
          "infra/*.py",
          "Dockerfile",
          "docker-compose.yml"
        ],
        "keywords": [
          "terraform",
          "packer",
          "yandex",
          "yc",
          "docker",
          "container",
          "vm",
          "instance",
          "helm",
          "kubernetes",
          "терраформ",
          "яндекс облак",
          "облачн инфр"
        ],
        "min_keyword_matches": 2,
        "always_load": false
      },
      "priority": 7
    },
    {
      "skill": "test-first-patterns",
      "triggers": {
        "files": [
          "tests/**/*.py",
          "conftest.py",
          "*.feature",
          "pytest.ini"
        ],
        "keywords": [
          "test",
          "pytest",
          "bdd",
          "gherkin",
          "fixture",
          "mock",
          "assert",
          "coverage",
          "tdd",
          "тест",
          "покрытие",
          "заглушк"
        ],
        "always_load": false
      },
      "priority": 8
    },
    {
      "skill": "github-actions",
      "triggers": {
        "files": [
          ".github/workflows/*.yml",
          ".github/workflows/*.yaml"
        ],
        "keywords": [
          "github actions",
          "ci",
          "workflow",
          "lint job",
          "test job",
          "deploy",
          "matrix",
          "pipeline"
        ],
        "always_load": false
      },
      "priority": 9
    },
    {
      "skill": "design-doc-creator",
      "optional": true,
      "triggers": {
        "files": [
          "design-doc.md",
          "DESIGN.md"
        ],
        "keywords": [
          "design document",
          "design doc",
          "requirements",
          "user story",
          "specification",
          "functional requirements",
          "nfr",
          "техзадание",
          "требовани",
          "спецификац"
        ],
        "always_load": false
      },
      "priority": 10
    },
    {
      "skill": "skill-developer",
      "optional": true,
      "triggers": {
        "files": [
          ".claude/skills/**"
        ],
        "keywords": [
          "create skill",
          "new skill",
          "skill template",
          "skill-rules"
        ],
        "always_load": false
      },
      "priority": 11
    },
    {
      "skill": "nlp-slm-patterns",
      "triggers": {
        "files": [
          "nlp/*.py",
          "anonymiz*.py",
          "presidio*.py"
        ],
        "keywords": [
          "nlp",
          "slm",
          "anonymiz",
          "presidio",
          "spacy",
          "ner",
          "ollama",
          "vllm",
          "local model",
          "transformers",
          "pii",
          "анонимизац"
        ],
        "always_load": false
      },
      "priority": 12
    },
    {
      "skill": "predictive-analytics",
      "triggers": {
        "files": [
          "ml/*.py",
          "features/*.py",
          "mlruns/**"
        ],
        "keywords": [
          "sklearn",
          "scikit",
          "mlflow",
          "classifier",
          "regressor",
          "feature engineering",
          "cross-validation",
          "training",
          "optuna",
          "shap"
        ],
        "always_load": false
      },
      "priority": 13
    },
    {
      "skill": "rag-vector-db",
      "triggers": {
        "files": [
          "adapters/vector*.py",
          "adapters/qdrant*.py",
          "services/rag*.py",
          "services/ingestion*.py"
        ],
        "keywords": [
          "qdrant",
          "pgvector",
          "embedding",
          "vector store",
          "chunking",
          "rag",
          "retrieval",
          "ingestion pipeline",
          "knowledge base",
          "semantic search",
          "эмбеддинг",
          "индексац",
          "база знаний",
          "семантическ"
        ],
        "always_load": false
      },
      "priority": 14
    },
    {
      "skill": "claude-api-patterns",
      "triggers": {
        "files": [
          "*.py"
        ],
        "keywords": [
          "anthropic",
          "claude api",
          "tool_use",
          "MessageCreate",
          "client.messages",
          "claude-sonnet",
          "claude-haiku",
          "claude-opus",
          "@anthropic-ai/sdk"
        ]
      },
      "priority": 15
    },
    {
      "skill": "prompt-engineering",
      "triggers": {
        "files": [
          "prompts/*.md",
          "prompts/*.txt",
          "prompts/*.py"
        ],
        "keywords": [
          "system_prompt",
          "few_shot",
          "chain-of-thought",
          "prompt template",
          "prompt engineering",
          "промпт",
          "system prompt",
          "eval",
          "few-shot",
          "system message",
          "instructions",
          "prompt design"
        ]
      },
      "priority": 16
    },
    {
      "skill": "experiment-tracking",
      "triggers": {
        "files": [
          "mlruns/**",
          "mlflow.db",
          "training/*.py",
          "experiments/*.py"
        ],
        "keywords": [
          "mlflow",
          "experiment",
          "run",
          "model registry",
          "artifact",
          "tracking",
          "log_metric",
          "log_params",
          "autolog",
          "tracking_uri",
          "compare runs",
          "registered model",
          "эксперимент mlflow"
        ],
        "min_keyword_matches": 2,
        "always_load": false
      },
      "priority": 17
    },
    {
      "skill": "data-validation",
      "triggers": {
        "files": [
          "schemas/*.py",
          "validation/*.py",
          "contracts/*.py",
          "models/*.py"
        ],
        "keywords": [
          "pandera",
          "great expectations",
          "data quality",
          "schema validation",
          "data contract",
          "DataFrameModel",
          "validate",
          "pydantic",
          "validator",
          "field_validator",
          "model_validator",
          "валидац данных",
          "качество данных"
        ],
        "min_keyword_matches": 2,
        "always_load": false
      },
      "priority": 18
    },
    {
      "skill": "critical-analysis",
      "description": "Auto-analytics by default: 8-role SPP critique for ML experiments and architecture",
      "triggers": {
        "files": [],
        "keywords": [
          "hypothesis",
          "experiment",
          "baseline",
          "plateau",
          "clustering",
          "refactor",
          "integration",
          "design decision",
          "critique",
          "crutch",
          "pivot",
          "optimize",
          "bottleneck",
          "tradeoff",
          "parameter",
          "validation",
          "quality",
          "approach",
          "pipeline",
          "metric",
          "гипотеза",
          "эксперимент",
          "архитектур",
          "рефактор",
          "стратег",
          "итерац",
          "параметр",
          "валидац",
          "качеств",
          "подход",
          "улучш",
          "пайплайн",
          "метрик",
          "боттлнек",
          "костыль",
          "кластер",
          "оптимиз"
        ],
        "min_keyword_matches": 2,
        "always_load": false
      },
      "priority": 0
    },
    {
      "skill": "database-migration-safety",
      "triggers": {
        "files": [
          "alembic/*.py",
          "migrations/*.py",
          "*.sql",
          "**/schema.py",
          "alembic.ini"
        ],
        "keywords": [
          "alembic",
          "migration",
          "schema",
          "upgrade",
          "downgrade",
          "revision",
          "rollback",
          "foreign key",
          "constraint",
          "ALTER TABLE",
          "миграц",
          "схем"
        ],
        "min_keyword_matches": 2,
        "always_load": false
      },
      "priority": 19
    },
    {
      "skill": "supply-chain-auditor",
      "triggers": {
        "files": [
          "requirements.txt",
          "pyproject.toml",
          "package.json",
          "Gemfile",
          "go.mod",
          "Cargo.toml"
        ],
        "keywords": [
          "dependency",
          "package",
          "install",
          "pip install",
          "npm install",
          "vulnerable",
          "CVE",
          "audit",
          "зависимост",
          "пакет",
          "уязвимост"
        ],
        "min_keyword_matches": 2,
        "always_load": false
      },
      "priority": 20
    }
  ],
  "context_management": {
    "max_skills_per_session": 3,
    "compression_threshold_lines": 300,
    "status_file": "dev/status.md",
    "always_load_status": true
  }
}