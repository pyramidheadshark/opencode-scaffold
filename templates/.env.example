# Application
APP_NAME=project-name
APP_VERSION=0.1.0
ENVIRONMENT=development

# API Keys
OPENROUTER_API_KEY=sk-or-...

# Database (uncomment if used)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
# POSTGRES_USER=app
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=app

# Yandex Cloud Object Storage (uncomment if used)
# YC_ACCESS_KEY_ID=...
# YC_SECRET_ACCESS_KEY=...
# YC_BUCKET_NAME=...

# Local LLM (uncomment if used)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# Production LLM inference (uncomment if used)
# VLLM_BASE_URL=http://gpu-vm-ip:8000/v1
# VLLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# CORS (JSON array of allowed origins)
# ALLOWED_ORIGINS=["http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
