{
  "version": "1.0",
  "description": "Test fixture skill rules",
  "rules": [
    {
      "skill": "python-project-standards",
      "triggers": {
        "files": ["pyproject.toml", "*.py"],
        "keywords": ["lint", "ruff", "mypy", "pre-commit", "uv"],
        "always_load": true
      },
      "priority": 1
    },
    {
      "skill": "fastapi-patterns",
      "triggers": {
        "files": ["main.py", "api/*.py"],
        "keywords": ["fastapi", "router", "endpoint"],
        "always_load": false
      },
      "priority": 2
    },
    {
      "skill": "langgraph-patterns",
      "triggers": {
        "files": ["graph.py", "agent*.py"],
        "keywords": ["langgraph", "state", "graph", "node"],
        "min_keyword_matches": 2,
        "always_load": false
      },
      "priority": 3
    },
    {
      "skill": "design-doc-creator",
      "optional": true,
      "triggers": {
        "files": ["design-doc.md"],
        "keywords": ["design document", "design doc"],
        "always_load": false
      },
      "priority": 4
    }
  ],
  "context_management": {
    "max_skills_per_session": 3,
    "compression_threshold_lines": 300,
    "status_file": "dev/status.md",
    "always_load_status": true
  }
}
