{
  "name": "claude-scaffold",
  "version": "1.0.0",
  "description": "Personal Claude Code infrastructure for ML engineering projects.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "jest tests/hook/ --no-coverage && (python3 tests/infra/test_infra.py || python tests/infra/test_infra.py)",
    "test:hook": "jest tests/hook/ --no-coverage",
    "test:infra": "python3 tests/infra/test_infra.py || python tests/infra/test_infra.py",
    "test:watch": "jest tests/hook/ --watch",
    "check:budget": "python tests/infra/test_infra.py TestSkillMdFiles.test_skill_line_budget",
    "metrics": "node scripts/metrics-report.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "jest": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}